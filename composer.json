{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "magnusvin/adminer-laravel-bridge",
    "description": "Adminer Bridge for Laravel",
    "keywords": [
        "laravel",
        "magnusvin",
        "adminer",
        "adminer-bridge",
        "adminer-laravel-bridge"
    ],
    "homepage": "https://github.com/magnusvin/adminer-laravel-bridge",
    "license": "MIT",
    "authors": [
        {
            "name": "magnusvin",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^12.0||^13.0",
        "vrana/adminer": "^5.5",
        "vrana/jush": "^3.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.9",
        "laravel/pint": "^1.29",
        "laravel/pao": "^1.0",
        "orchestra/testbench": "^10.0||^11.0",
        "pestphp/pest": "^4.6",
        "pestphp/pest-plugin-laravel": "^4.1",
        "pestphp/pest-plugin-type-coverage": "^4.0",
        "phpstan/extension-installer": "^1.4"
    },
    "autoload": {
        "psr-4": {
            "AdminerBridge\\AdminerBridge\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AdminerBridge\\AdminerBridge\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@clear",
            "@prepare"
        ],
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve --ansi"
        ],
        "lint": [
            "vendor/bin/pint --parallel"
        ],
        "lint:check": [
            "vendor/bin/pint --parallel --test"
        ],
        "analyse": [
            "vendor/bin/phpstan analyse --memory-limit=1G"
        ],
        "test:types": [
            "vendor/bin/pest --type-coverage --min=100"
        ],
        "test:unit": [
            "vendor/bin/pest --parallel"
        ],
        "test": [
            "@analyse",
            "@lint:check",
            "@test:types",
            "@test:unit"
        ],
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi"
    },
    "extra": {
        "laravel": {
            "providers": [
                "AdminerBridge\\AdminerBridge\\AdminerBridgeServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}