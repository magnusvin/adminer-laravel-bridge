{
    "preset": "laravel",
    "rules": {
        "no_extra_blank_lines": {
            "tokens": [
                "curly_brace_block",
                "extra",
                "throw",
                "use"
            ]
        },
        "blank_line_before_statement": {
            "statements": [
                "break",
                "continue",
                "declare",
                "if",
                "return",
                "throw",
                "try"
            ]
        },
        "global_namespace_import": {
            "import_classes": true
        },
        "trailing_comma_in_multiline": {
            "elements": [
                "arguments",
                "arrays",
                "match",
                "parameters"
            ]
        }
    }
}
